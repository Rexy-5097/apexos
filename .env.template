# ================================================================
# ApexOS — ENVIRONMENT CONFIGURATION TEMPLATE
# ================================================================
# Copy this file to .env before running the project.
#   cp .env.template .env
#
# Never commit .env to version control.
# .env is already listed in .gitignore — verify before pushing.
# ================================================================

# ----------------------------------------------------------------
# SERVER
# ----------------------------------------------------------------
# Port exposed on the host machine.
# The container always listens internally on port 3000.
# Only change this if port 3000 is occupied on your host.
PORT=3000

# ----------------------------------------------------------------
# RECON TOOLKIT — REQUIRED FOR SCANNER FEATURES
# ----------------------------------------------------------------
# Without SCANNER_URL and SCANNER_KEY, the RECON toolkit returns
# HTTP 503. All other data layers function without these values.
#
# SCANNER_URL  : URL of your RECON backend service
# SCANNER_KEY  : Shared secret — must match APEXOS_KEY on the backend
#                Generate: openssl rand -hex 32
SCANNER_URL=
SCANNER_KEY=

# ----------------------------------------------------------------
# FLIGHT TRACKING — OPTIONAL (higher rate limits)
# ----------------------------------------------------------------
# OpenSky Network switched to OAuth2 in March 2025.
# Without credentials, anonymous rate limits apply (lower refresh).
# Register at: https://opensky-network.org
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# ----------------------------------------------------------------
# NASA FIRMS — OPTIONAL (active fire hotspots)
# ----------------------------------------------------------------
# Without a key, the fire layer may be throttled or unavailable.
# Register at: https://firms.modaps.eosdis.nasa.gov/api/map_key/
FIRMS_API_KEY=

# ----------------------------------------------------------------
# SATELLITE TRACKING — OPTIONAL
# ----------------------------------------------------------------
# Required for the live satellite layer via N2YO.
# Register at: https://www.n2yo.com (Profile → API Key)
N2YO_API_KEY=

# ----------------------------------------------------------------
# MARITIME TRACKING — OPTIONAL
# ----------------------------------------------------------------
# Required for live AIS vessel tracking beyond static port data.
# Register at: https://aisstream.io
AIS_API_KEY=

# ----------------------------------------------------------------
# ANALYTICS — OPTIONAL
# ----------------------------------------------------------------
# Add your own analytics provider if needed.
# Do not add third-party telemetry without user disclosure.
# NEXT_PUBLIC_ANALYTICS_ID=
